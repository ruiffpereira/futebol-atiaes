# Copia para .env (local) ou define no Coolify (Environment Variables).

# Palavra-passe do backoffice (login da organização)
ADMIN_PASSWORD=atiaes-troca-me

# Segredo para assinar os cookies de sessão (string longa e aleatória)
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=muda-me-para-uma-string-aleatoria-longa

# Web Push (VAPID). Gera o par com:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:torneio@atiaes.pt

# Pasta de dados (Docker/Coolify: volume em /data). Local: deixa vazio -> ./data
DATA_DIR=
